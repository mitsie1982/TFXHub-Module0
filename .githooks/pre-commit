#!/bin/sh
# .githooks/pre-commit - Git hook entrypoint (Windows compatible)
# Runs the PowerShell validator using an execution policy that works in locked-down environments.

SCRIPT="scripts/pre-commit-whatsapp-validate.ps1"

if command -v pwsh >/dev/null 2>&1; then
	pwsh -NoLogo -NoProfile -ExecutionPolicy Bypass -File "$SCRIPT"
	exit $?
fi

if command -v powershell >/dev/null 2>&1; then
	powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -File "$SCRIPT"
	exit $?
fi

echo "[ERROR] Neither pwsh nor powershell was found in PATH." >&2
exit 1
